{
  "name": "shiftswap-backend",
  "version": "1.0.0",
  "description": "Backend API for ShiftSwap - shift scheduling and swap management",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "psql -U postgres -d shiftswap -f src/db/migrations/001_create_employees_and_shifts.sql",
    "seed": "ts-node src/db/seed.ts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "dotenv": "^16.4.5",
    "cors": "^2.8.5",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "ts-node": "^10.9.2",
    "nodemon": "^3.1.4",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.15",
    "@types/cors": "^2.8.17",
    "@types/pg": "^8.11.6"
  }
}